[Unit]
Description=SearXNG
After=network-online.target

[Container]
Image=docker.io/searxng/searxng:latest
ContainerName=searxng

Environment=BASE_URL=http://localhost:8888/
Environment=INSTANCE_NAME=bog-searxng

Volume=%h/.config/searxng:/etc/searxng:Z

PublishPort=8888:8080

AutoUpdate=registry

[Service]
Restart=on-failure
TimeoutStartSec=60

[Install]
WantedBy=default.target