# Use 'latest' as default to match what the build-image action creates
ARG IMAGE_TAG=latest
ARG FROM_IMAGE=ghcr.io/chrislowles/bog-amd:${IMAGE_TAG}

FROM ${FROM_IMAGE}

# Install VM Tools
RUN rpm-ostree install \
        qemu-guest-agent open-vm-tools spice-vdagent && \
    rpm-ostree cleanup -m

LABEL variant="vm"
LABEL org.opencontainers.image.title="Bog VM"
LABEL org.opencontainers.image.description="Custom immutable Linux with minimal GNOME and VM guest tools"